{
  "name": "tastetrail",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/web",
    "apps/cli",
    "packages/shared",
    "packages/server"
  ],
  "scripts": {
    "build": "npm run build --workspace @tastetrail/cli && npm run build --workspace @tastetrail/web",
    "cli": "node apps/cli/dist/index.js",
    "dev:web": "npm run dev --workspace @tastetrail/web",
    "dev:cli": "npm run dev --workspace @tastetrail/cli",
    "lint": "npm run lint --workspace @tastetrail/web",
    "typecheck": "npm run typecheck --workspace @tastetrail/cli && npm run typecheck --workspace @tastetrail/web"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
