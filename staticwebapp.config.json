{
  "$schema": "https://json.schemastore.org/staticwebapp.config.json",
  "platform": {
    "apiRuntime": "node:20"
  },
  "routes": [
    {
      "route": "/api/auth/microsoft/device-code/config",
      "allowedRoles": []
    },
    {
      "route": "/api/auth/microsoft/cli-token",
      "allowedRoles": []
    },
    {
      "route": "/api/auth/microsoft/device-code/token",
      "allowedRoles": []
    },
    {
      "route": "/api/auth/status",
      "allowedRoles": []
    },
    {
      "route": "/api/*",
      "allowedRoles": ["authenticated"]
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "/*.{css,scss,js,png,gif,ico,jpg,svg,woff,woff2,ttf,eot}"
    ]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html",
      "statusCode": 200
    }
  },
  "mimeTypes": {
    ".json": "application/json",
    ".js": "text/javascript",
    ".css": "text/css"
  }
}
